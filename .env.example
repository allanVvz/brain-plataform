# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# n8n
N8N_BASE_URL=https://allanvvz.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key

# AI
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Workers
WORKER_INTERVAL=900
N8N_MIRROR_INTERVAL=300
HEALTH_CHECK_INTERVAL=120
KB_SYNC_INTERVAL=3600

# Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vault source
# local keeps reading OBSIDIAN_LOCAL_PATH/VAULT_PATH.
# github reads the vault through GitHub API and does not require a local repo.
VAULT_SOURCE_MODE=github
OBSIDIAN_LOCAL_PATH=C:\Ai-Brain\Ai-Brain
GITHUB_VAULT_REPO=owner/ai-brain-vault
GITHUB_VAULT_BRANCH=main
GITHUB_VAULT_ROOT=
GITHUB_TOKEN=your-github-token
